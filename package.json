{
  "name": "openhinotes-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Bare-bones WebUSB bridge for HiDock P1 — list, download, delete, push to server share, trigger external processing. Single container.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsx watch server/src/index.ts",
    "dev": "npm-run-all --parallel dev:client dev:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc -p server/tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p client/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/w3c-web-usb": "^1.0.10",
    "@vitejs/plugin-react": "^4.3.1",
    "npm-run-all": "^4.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^7.3.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
